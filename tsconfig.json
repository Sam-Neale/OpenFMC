{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",

		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,

		"isolatedModules": true,
		"noEmit": true,
		"sourceMap": true,
		"types": ["vite/client", "node"]
	},
	"include": ["src", "*.config.ts"]
}
